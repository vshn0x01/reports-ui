# Copy to `.env.production` or set in CI before `npm run build`.
# Vite inlines `VITE_*` at build time — redeploy after changes.
#
# Same host as this app (reverse proxy routes /api → backend):
VITE_API_BASE_URL=/api

# Only if the API is on another origin (unusual for your setup):
# VITE_API_BASE_URL=https://api.example.com
